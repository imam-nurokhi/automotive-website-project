# Production environment variables template
# Fill these in your hosting provider (Vercel / Railway / Supabase)

# PostgreSQL connection string for runtime (pooler) or direct when running migrations
DATABASE_URL=

# NextAuth / Next.js
NEXTAUTH_URL=
AUTH_SECRET=

# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# Optional: OpenAI, Sentry, other secrets
# OPENAI_API_KEY=
# SENTRY_DSN=
