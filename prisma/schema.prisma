// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  MECHANIC
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InventoryCategory {
  OIL
  FILTER
  BRAKE
  ELECTRICAL
  BODY
  ENGINE
  TRANSMISSION
  COOLING
  EXHAUST
  OTHER
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  vehicles       Vehicle[]
  serviceRecords ServiceRecord[] @relation("MechanicServices")
}

model Vehicle {
  id           String   @id @default(cuid())
  licensePlate String   @unique
  brand        String
  model        String
  year         Int
  color        String?
  engineCC     Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceRecords ServiceRecord[]
}

model ServiceRecord {
  id          String        @id @default(cuid())
  date        DateTime      @default(now())
  mileage     Int
  description String        @db.Text
  totalCost   Decimal       @db.Decimal(12, 2)
  status      ServiceStatus @default(PENDING)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vehicleId    String
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mechanicId   String?
  mechanic     User?         @relation("MechanicServices", fields: [mechanicId], references: [id])
  serviceItems ServiceItem[]
}

model Inventory {
  id               String            @id @default(cuid())
  itemCode         String            @unique
  name             String
  category         InventoryCategory @default(OTHER)
  stockQuantity    Int               @default(0)
  minimumThreshold Int               @default(5)
  price            Decimal           @db.Decimal(12, 2)
  unit             String            @default("pcs")
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  serviceItems ServiceItem[]
}

model ServiceItem {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  inventoryId     String
  inventory       Inventory     @relation(fields: [inventoryId], references: [id])
}

model Promo {
  id          String   @id @default(cuid())
  title       String
  image       String?
  description String   @db.Text
  discount    Int?
  validUntil  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

